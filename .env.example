# Database
DATABASE_URL="postgresql://user:password@localhost:5432/aivolve?schema=public"

# NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Email (Resend) - used for verification + password reset emails
RESEND_API_KEY="re_xxxxxxxxxxxx"
EMAIL_FROM="AIVolve <onboarding@aivolve.app>"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
